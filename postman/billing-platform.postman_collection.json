            "body": { "mode": "raw", "raw": "{\n  \"assignedToUserId\": null,\n  \"internalNotes\": \"Priority booking\"\n}" },
            "url": "{{gatewayBaseUrl}}/api/travel/bookings/from-quotation/{{quotationId}}"
          }
        },
        { "name": "List Bookings", "request": { "method": "GET", "header": [{ "key": "x-tenant-id", "value": "{{tenantId}}" }], "url": "{{gatewayBaseUrl}}/api/travel/bookings?page=1&pageSize=20&status=Pending&destination=Rome" } },
        { "name": "Get Booking By Id", "request": { "method": "GET", "header": [{ "key": "x-tenant-id", "value": "{{tenantId}}" }], "url": "{{gatewayBaseUrl}}/api/travel/bookings/{{bookingId}}" } },
