    {
      "name": "User Feature Assignment",
      "description": "Tenant-owned feature allocation and user/agent assignment workflow coverage.",
      "item": [
        {
          "name": "Get Tenant Feature Allocations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{billingBaseUrl}}/billing/tenants/{{tenantId}}/feature-allocations"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (Array.isArray(json) && json.length > 0 && json[0].featureKey) {",
                  "  pm.environment.set(\"assignedFeatureKey\", json[0].featureKey);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User Effective Features",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{billingBaseUrl}}/billing/tenants/{{tenantId}}/users/{{agentUserId}}/features"
          },
          "response": []
        },
        {
          "name": "Assign Features To User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"featureKeys\": [\n    \"{{assignedFeatureKey}}\"\n  ],\n  \"effectiveFrom\": \"2026-04-12T00:00:00Z\"\n}"
            },
            "url": "{{billingBaseUrl}}/billing/tenants/{{tenantId}}/users/{{agentUserId}}/feature-assignments"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.featureKey) pm.environment.set(\"assignedFeatureKey\", json.featureKey);"
                ]
              }
            }
          ]
        },
        {
          "name": "Bulk Assign Feature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operation\": \"Assign\",\n  \"featureKey\": \"{{assignedFeatureKey}}\",\n  \"userIds\": [\n    \"{{agentUserId}}\",\n    \"{{secondaryUserId}}\"\n  ]\n}"
            },
            "url": "{{billingBaseUrl}}/billing/tenants/{{tenantId}}/feature-assignments/bulk"
          },
          "response": []
        },
        {
          "name": "Revoke User Feature Assignment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{billingBaseUrl}}/billing/tenants/{{tenantId}}/users/{{agentUserId}}/feature-assignments/{{assignedFeatureKey}}"
          },
          "response": []
        },
        {
          "name": "Get My Feature Access",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{billingBaseUrl}}/billing/feature-access/me"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "resourceId",
      "value": "{{resourceId}}"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get(\"accessToken\");",
          "if (token) {",
          "  pm.request.headers.upsert({ key: \"Authorization\", value: `Bearer ${token}` });",
          "}"
        ]
      }
    }
  ]
