          "name": "Send Quotation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"revisionId\": \"{{revisionId}}\",\n  \"channel\": \"Email\",\n  \"recipientEmail\": \"traveler@example.com\",\n  \"message\": \"Please review your updated proposal.\",\n  \"expiresAt\": \"2026-05-01T00:00:00Z\"\n}" },
            "url": "{{gatewayBaseUrl}}/api/travel/quotations/{{quotationId}}/send"
          }
        },
        {
          "name": "Upload Quotation Attachment",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-tenant-id", "value": "{{tenantId}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "revisionId", "value": "{{revisionId}}", "type": "text" },
                { "key": "attachmentType", "value": "Brochure", "type": "text" },
                { "key": "caption", "value": "Hotel brochure", "type": "text" },
                { "key": "isCustomerVisible", "value": "true", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{gatewayBaseUrl}}/api/travel/quotations/{{quotationId}}/attachments"
          }
        },
        {
          "name": "Delete Quotation Attachment",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-tenant-id", "value": "{{tenantId}}" }],
            "url": "{{gatewayBaseUrl}}/api/travel/quotations/{{quotationId}}/attachments/{{attachmentId}}"
          }
        },
        { "name": "Get Public Quotation", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{travelBaseUrl}}/travel/quotations/public/{{shareToken}}" } },
        { "name": "Mark Public Quotation Viewed", "request": { "auth": { "type": "noauth" }, "method": "POST", "url": "{{travelBaseUrl}}/travel/quotations/public/{{shareToken}}/viewed" } },
        {
          "name": "Create Booking From Quotation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
