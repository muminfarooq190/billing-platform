{
  "FeatureEntitlements": {
    "Routes": [
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/assign", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/qualify", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/disqualify", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/mark-contacted", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/archive", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/convert-to-quotation", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/concepts", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/concepts/{conceptId}/mark-primary", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/inquiries/{id}/concepts/{conceptId}/archive", "FeatureKey": "travel.inquiries.write" },
      { "Method": "POST", "PathPrefix": "/api/travel/quotations", "FeatureKey": "travel.quotation.create" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/send", "FeatureKey": "travel.quotation.send" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/approval-requests", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/approval-requests/{approvalRequestId}/approve", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/approval-requests/{approvalRequestId}/reject", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/accept", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/reject", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/expire", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/revisions", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPattern": "/api/travel/quotations/{id}/attachments", "FeatureKey": "travel.quotation.write" },
      { "Method": "DELETE", "PathPattern": "/api/travel/quotations/{id}/attachments/{attachmentId}", "FeatureKey": "travel.quotation.write" },
      { "Method": "POST", "PathPrefix": "/api/travel/bookings/from-quotation", "FeatureKey": "travel.booking.create" },
      { "Method": "POST", "PathPattern": "/api/travel/bookings/{id}/itinerary", "FeatureKey": "travel.itineraries.write" },
      { "Method": "POST", "PathPattern": "/api/travel/bookings/{id}/travelers", "FeatureKey": "travel.bookings.write" },
      { "Method": "PUT", "PathPattern": "/api/travel/bookings/{id}/travelers/{travelerId}", "FeatureKey": "travel.bookings.write" },
      { "Method": "DELETE", "PathPattern": "/api/travel/bookings/{id}/travelers/{travelerId}", "FeatureKey": "travel.bookings.write" },
      { "Method": "POST", "PathPattern": "/api/travel/bookings/{id}/items", "FeatureKey": "travel.bookings.write" },
      { "Method": "PUT", "PathPattern": "/api/travel/bookings/{id}/items/{itemId}", "FeatureKey": "travel.bookings.write" },
      { "Method": "PATCH", "PathPattern": "/api/travel/bookings/{id}/items/{itemId}/status", "FeatureKey": "travel.bookings.write" },
      { "Method": "POST", "PathPattern": "/api/travel/bookings/{id}/items/{itemId}/request-confirmation", "FeatureKey": "travel.bookings.write" },
      { "Method": "POST", "PathPattern": "/api/travel/bookings/{id}/items/{itemId}/confirm", "FeatureKey": "travel.bookings.write" },
      { "Method": "POST", "PathPattern": "/api/travel/bookings/{id}/items/{itemId}/issue", "FeatureKey": "travel.bookings.write" },
      { "Method": "DELETE", "PathPattern": "/api/travel/bookings/{id}/items/{itemId}", "FeatureKey": "travel.bookings.write" },
      { "Method": "POST", "PathPattern": "/api/travel/bookings/{id}/documents", "FeatureKey": "travel.booking.documents.upload" },
      { "Method": "DELETE", "PathPattern": "/api/travel/bookings/{id}/documents/{documentId}", "FeatureKey": "travel.bookings.write" },
      { "Method": "PUT", "PathPattern": "/api/travel/itineraries/{id}", "FeatureKey": "travel.itineraries.write" },
      { "Method": "GET", "PathPrefix": "/api/travel/timeline", "FeatureKey": "travel.timeline.read" },
      { "Method": "GET", "PathPrefix": "/api/travel/admin/audit", "FeatureKey": "travel.audit.read" },
      { "Method": "POST", "PathPrefix": "/api/communication/notifications", "FeatureKey": "communication.notification.send" },
      { "Method": "GET", "PathPrefix": "/api/communication/notifications/recipient", "FeatureKey": "communication.logs.read" },
      { "Method": "POST", "PathPrefix": "/api/communication/templates", "FeatureKey": "communication.templates.manage" },
      { "Method": "PUT", "PathPrefix": "/api/communication/templates", "FeatureKey": "communication.templates.manage" },
      { "Method": "GET", "PathPrefix": "/api/communication/templates", "FeatureKey": "communication.templates.manage" },
      { "Method": "GET", "PathPrefix": "/api/identity/audit/users", "FeatureKey": "identity.audit.read" },
      { "Method": "GET", "PathPrefix": "/api/identity/security-events", "FeatureKey": "identity.audit.read" },
      { "Method": "GET", "PathPrefix": "/api/identity/audit/export", "FeatureKey": "identity.audit.export" },
      { "Method": "GET", "PathPrefix": "/api/identity/roles", "FeatureKey": "identity.rbac.advanced" },
      { "Method": "POST", "PathPrefix": "/api/identity/roles", "FeatureKey": "identity.rbac.advanced" },
      { "Method": "PUT", "PathPrefix": "/api/identity/roles", "FeatureKey": "identity.rbac.advanced" },
      { "Method": "PUT", "PathPrefix": "/api/identity/users", "FeatureKey": "identity.rbac.advanced" },
      { "Method": "GET", "PathPrefix": "/api/geo-leads", "FeatureKey": "geo-leads.read" },
      { "Method": "POST", "PathPrefix": "/api/geo-leads", "FeatureKey": "geo-leads.manage" },
      { "Method": "PUT", "PathPrefix": "/api/geo-leads", "FeatureKey": "geo-leads.manage" },
      { "Method": "DELETE", "PathPrefix": "/api/geo-leads", "FeatureKey": "geo-leads.manage" }
    ]
  },
  "Yarp": {
    "ReverseProxy": {
      "Routes": {
        "auth-route": {
          "ClusterId": "identity-cluster",
          "Match": { "Path": "/api/auth/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/auth/{**catch-all}" }
          ]
        },
        "identity-route": {
          "ClusterId": "identity-cluster",
          "Match": { "Path": "/api/identity/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/identity/{**catch-all}" }
          ]
        },
        "tenant-branding-route": {
          "ClusterId": "identity-cluster",
          "Match": { "Path": "/api/tenant-branding/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/tenant-branding/{**catch-all}" }
          ]
        },
        "billing-route": {
          "ClusterId": "billing-cluster",
          "Match": { "Path": "/api/billing/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/billing/{**catch-all}" }
          ]
        },
        "webhook-route": {
          "ClusterId": "webhook-cluster",
          "Match": { "Path": "/api/webhooks/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/webhooks/{**catch-all}" }
          ]
        },
        "travel-route": {
          "ClusterId": "travel-cluster",
          "Match": { "Path": "/api/travel/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/travel/{**catch-all}" }
          ]
        },
        "communication-route": {
          "ClusterId": "communication-cluster",
          "Match": { "Path": "/api/communication/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/communication/{**catch-all}" }
          ]
        },
        "geo-leads-route": {
          "ClusterId": "geo-leads-cluster",
          "Match": { "Path": "/api/geo-leads/{**catch-all}" },
          "Transforms": [
            { "PathPattern": "/geo-leads/{**catch-all}" }
          ]
        }
      },
      "Clusters": {
        "identity-cluster": {
          "LoadBalancingPolicy": "RoundRobin",
          "Destinations": {
            "d1": { "Address": "http://identity-service:8080/" }
          }
        },
        "billing-cluster": {
          "LoadBalancingPolicy": "RoundRobin",
          "Destinations": {
            "d1": { "Address": "http://billing-service:8080/" }
          }
        },
        "webhook-cluster": {
          "LoadBalancingPolicy": "RoundRobin",
          "Destinations": {
            "d1": { "Address": "http://webhook-service:3000/" }
          }
        },
        "travel-cluster": {
          "LoadBalancingPolicy": "RoundRobin",
          "Destinations": {
            "d1": { "Address": "http://travel-service:8080/" }
          }
        },
        "communication-cluster": {
          "LoadBalancingPolicy": "RoundRobin",
          "Destinations": {
            "d1": { "Address": "http://communication-service:8080/" }
          }
        },
        "geo-leads-cluster": {
          "LoadBalancingPolicy": "RoundRobin",
          "Destinations": {
            "d1": { "Address": "http://geo-leads-service:8080/" }
          }
        }
      }
    }
  }
}
