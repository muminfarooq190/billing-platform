# ------------------------------------------------------------
# Core infrastructure credentials
# ------------------------------------------------------------
POSTGRES_DB=billing
POSTGRES_USER=billing_user
POSTGRES_PASSWORD=replace-with-strong-password

RABBITMQ_DEFAULT_USER=billing_rmq
RABBITMQ_DEFAULT_PASS=replace-with-strong-password

# ------------------------------------------------------------
# Service connection strings
# ------------------------------------------------------------
IDENTITY_DATABASE_URL=Host=postgres;Port=5432;Database=billing_identity;Username=billing_user;Password=replace-with-strong-password
BILLING_DATABASE_URL=Host=postgres;Port=5432;Database=billing_billing;Username=billing_user;Password=replace-with-strong-password
WEBHOOK_DATABASE_URL=postgresql://billing_user:replace-with-strong-password@postgres:5432/billing_webhook
TRAVEL_DATABASE_URL=Host=postgres;Port=5432;Database=billing_travel;Username=billing_user;Password=replace-with-strong-password
COMMUNICATION_DATABASE_URL=Host=postgres;Port=5432;Database=billing_communication;Username=billing_user;Password=replace-with-strong-password
GEO_LEADS_DATABASE_URL=Host=postgres;Port=5432;Database=billing_geo_leads;Username=billing_user;Password=replace-with-strong-password

RABBITMQ_URL=amqp://billing_rmq:replace-with-strong-password@rabbitmq:5672
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# Auth and security
# Use mounted key files for Docker Compose parity.
# ------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt-public.pem
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----REPLACE_ME-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----REPLACE_ME-----END PUBLIC KEY-----

# ------------------------------------------------------------
# Billing/payment settings
# ------------------------------------------------------------
PAYMENT_GATEWAY=Mock
STRIPE_SECRET_KEY=sk_test_replace_me

# ------------------------------------------------------------
# Communication providers
# Defaults stay on safe log providers until real credentials are supplied.
# ------------------------------------------------------------
EMAIL_PROVIDER=log
EMAIL_DEFAULT_FROM_EMAIL=notifications@example.com
EMAIL_DEFAULT_FROM_NAME=Billing Platform
SENDGRID_API_KEY=
SENDGRID_BASE_URL=https://api.sendgrid.com/

SMS_PROVIDER=log
SMS_DEFAULT_FROM_NUMBER=+15555550123
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_BASE_URL=https://api.twilio.com/

# ------------------------------------------------------------
# Observability settings
# ------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
